---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import ReferralListClient from '../components/ReferralListClient';

// Get query parameters
const { searchParams } = Astro.url;
const page = parseInt(searchParams.get('page') || '1');
const search = searchParams.get('search');
const categoryId = searchParams.get('category');

// Set page size
const pageSize = 12;

// Calculate offset for pagination
const offset = (page - 1) * pageSize;

// Build query
let query = supabase
  .from('referral_codes')
  .select('*, categories(name)', { count: 'exact' });

if (categoryId) {
  query = query.eq('category_id', categoryId);
}

if (search) {
  query = query.ilike('app_name', `%${search}%`);
}

// Execute query with pagination
const { data: referrals, count, error } = await query
  .order('created_at', { ascending: false })
  .range(offset, offset + pageSize - 1);

// Calculate total pages
const totalPages = count ? Math.ceil(count / pageSize) : 0;
---

<Layout title="All Referral Codes | Find and Share Referrals">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">All Referral Codes</h1>
    <p class="mt-2 text-gray-600">Browse and search for referral codes across various services and apps.</p>
  </div>
  
  <ReferralListClient 
    initialReferrals={referrals || []} 
    categoryId={categoryId}
    search={search}
    page={page}
    totalPages={totalPages}
    client:load
  />
</Layout>
